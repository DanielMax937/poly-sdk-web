# Polymarket API Configuration
# Copy this file to .env.local and fill in your credentials

# Outbound proxy for Polymarket Gamma/CLOB (HTTPS). Prefer HTTPS_PROXY; HTTP_PROXY and ALL_PROXY also work.
# HTTPS_PROXY=http://127.0.0.1:1087
# Optional: fail snapshot:themes if proxy is not set (1 = require)
# POLYMARKET_REQUIRE_PROXY=0

# Your wallet's private key (without 0x prefix)
POLY_PRIVATE_KEY=

# L2 API Credentials (get from createOrDeriveApiKey())
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# Optional: Signature type (0=EOA, 1=Gnosis Safe, 2=MagicLink)
POLY_SIGNATURE_TYPE=0

# Optional: Funder address (leave empty to use wallet address)
POLY_FUNDER_ADDRESS=
# VolcEngine (Ark) LLM for futures query rewrite
VOLC_API_KEY=
VOLC_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLC_MODEL=
