# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results/
/playwright-report/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Secrets & API keys (LLM: VOLC_* / OPENAI_* / ANTHROPIC_*; Polymarket: POLY_*)
# Never commit real keys — only .env.example templates.
.env*
!.env.example
# direnv / local overrides that often hold keys
.envrc

# local-service background (start-bg.sh / stop-bg.sh)
poly-sdk-web.pid
poly-sdk-web.log

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
