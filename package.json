{
  "name": "poly-sdk-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS=\"--dns-result-order=ipv4first\" next dev",
    "dev:proxy": "HTTPS_PROXY=\"http://127.0.0.1:1087\" HTTP_PROXY=\"http://127.0.0.1:1087\" NODE_OPTIONS=\"--dns-result-order=ipv4first\" next dev",
    "build": "next build",
    "start": "NODE_OPTIONS=\"--dns-result-order=ipv4first\" next start",
    "start:proxy": "HTTPS_PROXY=\"http://127.0.0.1:1087\" HTTP_PROXY=\"http://127.0.0.1:1087\" NODE_OPTIONS=\"--dns-result-order=ipv4first\" next start",
    "lint": "eslint",
    "test": "jest",
    "test:e2e": "playwright test",
    "snapshot:themes": "NODE_OPTIONS=\"--dns-result-order=ipv4first\" tsx scripts/polymarket-theme-snapshot.ts",
    "snapshot:themes:proxy": "HTTPS_PROXY=\"http://127.0.0.1:1087\" HTTP_PROXY=\"http://127.0.0.1:1087\" NODE_OPTIONS=\"--dns-result-order=ipv4first\" tsx scripts/polymarket-theme-snapshot.ts"
  },
  "dependencies": {
    "next": "16.1.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "undici": "^6.19.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4",
    "@types/jest": "^29",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "jest": "^29",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
